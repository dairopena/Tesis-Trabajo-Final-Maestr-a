{
  // Configuración de archivos
  "files.associations": {
    "*.tex": "latex",
    "*.bib": "bibtex"
  },

  // Excluir archivos de compilación de la búsqueda
  "files.exclude": {
    "**/.git": true,
    "**/.DS_Store": true,
    "**/build/*.aux": true,
    "**/build/*.bbl": true,
    "**/build/*.bcf": true,
    "**/build/*.blg": true,
    "**/build/*.log": true,
    "**/build/*.out": true,
    "**/build/*.run.xml": true,
    "**/build/*.fls": true,
    "**/build/*.fdb_latexmk": true,
    "**/build/*.toc": true,
    "**/build/*.lof": true,
    "**/build/*.lot": true
  },

  // Configuración del explorador de archivos
  "explorer.confirmDelete": false,

  // Guardar automáticamente
  "files.autoSave": "onFocusChange",

  // Configuración de LaTeX Workshop (si está instalado)
  "latex-workshop.latex.outDir": "./build",
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.latex.build.forceRecipeUsage": true,
  "latex-workshop.latex.recipe.default": "first",
  "latex-workshop.latex.recipes": [
    {
      "name": "XeLaTeX + Biber + XeLaTeX x2 (Tesis UNAL)",
      "tools": ["xelatex", "biber", "xelatex", "xelatex"]
    },
    {
      "name": "latexmk (XeLaTeX + Biber automático)",
      "tools": ["latexmk"]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "xelatex",
      "command": "xelatex",
      "args": [
        "-interaction=nonstopmode",
        "-shell-escape",
        "-synctex=1",
        "-output-directory=build",
        "%DOC%"
      ]
    },
    {
      "name": "biber",
      "command": "biber",
      "args": ["build/%DOCFILE%"],
      "env": {}
    },
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-xelatex",
        "-interaction=nonstopmode",
        "-shell-escape",
        "-output-directory=build",
        "-file-line-error",
        "-synctex=1",
        "%DOC%"
      ]
    }
  ],
  "latex-workshop.view.pdf.viewer": "tab",
  "latex-workshop.latex.clean.subfolder.enabled": true,
  "latex-workshop.latex.autoClean.run": "onBuilt",

  // Configuración de SyncTeX para saltar entre PDF y código
  "latex-workshop.synctex.afterBuild.enabled": true,
  "latex-workshop.synctex.synctexjs.enabled": true,
  "latex-workshop.view.pdf.internal.synctex.keybinding": "double-click"
}
