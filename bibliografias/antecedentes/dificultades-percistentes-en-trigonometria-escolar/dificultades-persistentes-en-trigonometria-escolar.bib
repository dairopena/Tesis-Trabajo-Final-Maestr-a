@article{alabiTransformingSocialStudies2025a,
  title = {Transforming {{Social Studies Pedagogy}}: {{Artificial Intelligence-Based}} Tool and {{Students}}’ {{Academic Performance}} in {{Ondo State}}, {{Nigeria}}},
  shorttitle = {Transforming {{Social Studies Pedagogy}}},
  author = {Alabi, Abidoye James and Adelekan, Akeem Tunde and Olotu, Gbenga},
  date = {2025-11-27},
  journaltitle = {ETDC: Indonesian Journal of Research and Educational Review},
  volume = {5},
  number = {1},
  pages = {45--54},
  issn = {2809-3682},
  doi = {10.51574/ijrer.v5i1.3988},
  url = {https://etdci.org/journal/ijrer/article/view/3988},
  urldate = {2026-04-08},
  abstract = {This study examined the transformation of social studies pedagogy through artificial intelligence-based tools and students’ academic performance in Ondo State, Nigeria. This study adopted a pre-test, post-test control group quasi-experimental research design. Three objectives were set for the study, and three research hypotheses were formulated to guide it. The population for the study consisted of all secondary students in Ondo State. The sample population comprised 163 Junior Secondary School (JSS II) students drawn from four public secondary schools randomly selected in the Ondo West Local Government Area of Ondo State, Nigeria. Two instruments were used in the study. They are the Social Studies Performance Test (SSPT) and the Modified Lesson Note (MLN). All the instruments were validated by experts. The reliability of the instrument (SSPT) was determined, and a reliability coefficient of 0.83 was obtained. Students' academic data was collected, and we analyzed covariances (ANCOVA). variance (ANCOVA). The social studies that students exposed to ITS demonstrated significantly higher academic performance than those taught by other methods (F (1,154) = 111.124, p \&lt; 0.05, partial η² = .419). The findings also revealed no significant effects of gender and school location on students' academic performance. This evidence suggests that intelligent tutoring systems (ITS) provide equitable learning opportunities. The study recommends increased investment in ICT infrastructure, teacher training, and policy interventions to enhance ITS integration into the teaching and learning of secondary schools’ subjects.},
  langid = {english},
  keywords = {Academic Performance,ICT Integration,Intelligent Tutoring System,Secondary Education,Social Studies},
  file = {/home/Dairo/Zotero/storage/KSBU2CEK/Alabi et al. - 2025 - Transforming Social Studies Pedagogy Artificial Intelligence-Based tool and Students’ Academic Perf.pdf}
}

@article{arhinAnalysisHighSchool2021,
  title = {Analysis of {{High School Students}}’ {{Errors}} in {{Solving Trigonometry Problems}}},
  author = {Arhin, Jacob and Hokor, Evans Kofi},
  date = {2021-07-13},
  journaltitle = {Journal of Mathematics and Science Teacher},
  volume = {1},
  number = {1},
  pages = {em003},
  publisher = {Modestum},
  issn = {2752-6054},
  doi = {10.29333/mathsciteacher/11076},
  url = {https://www.mathsciteacher.com/article/analysis-of-high-school-students-errors-in-solving-trigonometry-problems-11076},
  urldate = {2026-04-08},
  abstract = {This study examined High School students’ error displayed in solving trigonometry problems. The literature revealed that trigonometry is difficult for students to understand and our paper contends that identifying students’ error and understanding how the errors occurred can serve as a point of reference for instructional decisions which will make the concept easier. The study uses a quantitative research techniques to explore students’ errors in solving trigonometry problems. Ninety students were sampled using multistage sample techniques. Trigonometry Achievement Test (TAT) was used in data collection. Descriptive statistics (figures and tables) was used to present the students’ error after content analysis was carried out and Modified Newman’s Error Hierarchy was used in classifying students’ error. The results revealed most students’ errors occurs at transforming, processing and encoding stages. Independent sample t-test was used to compare the errors committed by male and female students. Independent samples t-test of groups’ differences in means among male and female students indicated that, there was a significant difference in their mean scores at t(89) = 2.198, p {$<$} .05. Thus, female students’ level of committing errors in solving trigonometry problems was significantly higher than their male counterparts. The study recommends that Mathematics teachers should make the teaching of trigonometry practical and more activity-oriented to limit students’ error in solving trigonometry problem most importantly among the female students.},
  langid = {english},
  file = {/home/Dairo/Zotero/storage/VJZB3CLP/Arhin y Hokor - 2021 - Analysis of High School Students’ Errors in Solving Trigonometry Problems.pdf}
}

@article{orozcoImpactProblemSolving2025,
  title = {Impact of Problem Solving on Trigonometric Learning in {{Afro-Colombian}} Communities},
  author = {Orozco, Pedro Hurtado and Acosta, Adolfo Pimienta and Barrios, John Moreno and Pino, Alexander Leones},
  date = {2025-09-18},
  journaltitle = {Frontiers in Education},
  shortjournal = {Front. Educ.},
  volume = {10},
  publisher = {Frontiers},
  issn = {2504-284X},
  doi = {10.3389/feduc.2025.1626007},
  url = {https://www.frontiersin.org/journals/education/articles/10.3389/feduc.2025.1626007/full},
  urldate = {2026-04-08},
  abstract = {The article advocates for the need to adapt trigonometry teaching to Afro-Colombian communities through appropriate strategies that reflect their environment and culture, arguing that the use of authentic problem-solving is a relevant didactic design to foster meaningful learning, promote motivation, and strengthen students' identity. It is a qualitative, theoretical-conceptual study framed within the socio-critical paradigm and guided by the principles of Participatory Action Research (PAR). Although no fieldwork was conducted, a critical review of pedagogical, academic, and policy-related literature was carried out to support the design of a relevant educational proposal. The theoretical framework is built upon contextualized problem-solving, critical mathematics education, ethnomathematics, and PAR. It argues that teaching trigonometry through real-life problems enhances conceptual understanding, critical thinking, and the application of mathematical knowledge to everyday situations. Moreover, it highlights the potential for integrating ancestral knowledge related to navigation, topography, or Afro-Colombian craftsmanship. The results reveal both pedagogical and social advantages, as well as tensions and challenges such as misalignment with the official curriculum, gaps in teacher training, and limited resources. Nonetheless, the study also identifies opportunities to enrich teaching with culturally meaningful content. Finally, it proposes organizing participatory projects that connect teachers, students, and the community in the development of contextualized didactic materials, aiming for a more equitable, critical, and transformative mathematics education.},
  langid = {english},
  keywords = {contextualized trigonometry,critical mathematics education,ethnomathematics,experiential learning,problem solving},
  file = {/home/Dairo/Zotero/storage/2CMG8WQB/Orozco et al. - 2025 - Impact of problem solving on trigonometric learning in Afro-Colombian communities.pdf}
}

@article{owusuStudentsAcademicStruggles2025,
  title = {Students’ Academic Struggles in Solving Trigonometry Problems: An Investigative Study on Students’ Programs of Study},
  shorttitle = {Students’ Academic Struggles in Solving Trigonometry Problems},
  author = {Owusu, Ebenezer and Banson, Gideon Mensah and Lotey, Ebenezer Kwesi and Owusu, Raphael and Ofosua, Benedicta and Arthur, Yarhands Dissou},
  date = {2025-12-31},
  journaltitle = {Cogent Education},
  volume = {12},
  number = {1},
  pages = {2563166},
  publisher = {Cogent OA},
  issn = {null},
  doi = {10.1080/2331186X.2025.2563166},
  url = {https://doi.org/10.1080/2331186X.2025.2563166},
  urldate = {2026-04-08},
  abstract = {Trigonometry remains one of the most challenging topics in the Ghanaian mathematics curriculum, with many students facing challenges in their quest to comprehend and solve related problems. Notable differences in student performance across academic programs prompted this study, which explored how students’ program of study in senior high school influences their academic performance in trigonometry problem-solving and examined the factors behind program-based variations in students’ trigonometry performance. Utilising a mixed-method approach, a sample of 100 final-year high school students underwent assessment via a Trigonometry Achievement Test (TAT). Descriptive and inferential statistical analyses were employed for the quantitative data, while qualitative responses were analysed thematically. ANOVA results showed statistically significant differences in performance by academic program (α = 0.05, F (5,94) = 56.04, p {$<$} 0.01), with General Science students performing the highest and Home Economics students performing the lowest. The qualitative analysis revealed several factors contributing to these differences, including students’ perceived relevance of trigonometry to their future careers, levels of motivation and interest, peer influence, and study habits. These findings suggest that students’ academic programs shape both their engagement with mathematics and their success in solving trigonometric problems.},
  keywords = {Academic performance,Education,Ghanaian SHS,Mathematics Education,mixed-method analysis,program of study,Social Sciences,Teaching & Learning,trigonometry word problems},
  file = {/home/Dairo/Zotero/storage/7BKSV5LA/Owusu et al. - 2025 - Students’ academic struggles in solving trigonometry problems an investigative study on students’ p.pdf}
}
