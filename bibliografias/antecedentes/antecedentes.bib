@article{mirelesAplicacionInteligenciaArtificial2025,
  title = {Aplicación de la inteligencia artificial en la evaluación formativa un enfoque para la retroalimentación inmediata y mejora del rendimiento académico},
  author = {Mireles, Miguel Ángel Rodríguez},
