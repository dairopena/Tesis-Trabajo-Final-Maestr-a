@article{iriarteDificultadesAprendizajeEcuaciones2025,
  title = {Dificultades en el aprendizaje de ecuaciones trigonométricas en estudiantes de primer año de ingeniería: Un estudio en la Universidad de Atacama, Chile},
  shorttitle = {Dificultades en el aprendizaje de ecuaciones trigonométricas en estudiantes de primer año de ingeniería},
  author = {Iriarte, Ricardo Alex Guerra and Guzman, Ismenia and Morales, Felipe Guevara},
  date = {2025-08-01},
  journaltitle = {Revista Chilena de Educación Matemática},
  volume = {17},
  number = {2},
  pages = {40--51},
  issn = {2452-5448},
  doi = {10.46219/rechiem.v17i2.176},
  url = {https://www.sochiem.cl/revista-rechiem/index.php/rechiem/article/view/176},
  urldate = {2025-11-26},
  abstract = {Esta investigación surge a partir de los conocimientos insuficientes evidenciados por estudiantes del curso inicial de Álgebra I de Ingeniería Civil en la Universidad de Atacama. Su propósito principal es indagar en las dificultades y errores que enfrentan al resolver ejercicios de trigonometría. Se adoptó una metodología cualitativa descriptiva, con validación interna, utilizando como instrumentos dos problemas extraídos de una evaluación. Mediante el análisis didáctico, se examinaron los objetivos de cada problema y las respuestas textuales de los estudiantes, lo que permitió determinar el conocimiento matemático requerido y las habilidades cognitivas necesarias para su resolución. Los resultados evidencian que las prácticas docentes presentan limitaciones en el refuerzo del cambio entre registros semióticos, aspecto que incide en la comprensión de los estudiantes. Asimismo, el análisis de las producciones escritas permitió identificar deficiencias en la operatoria con fracciones algebraicas y en la resolución de ecuaciones trigonométricas. Finalmente, se observó que los estudiantes presentan dificultades en la transición desde un álgebra escolar, centrada en procedimientos, hacia un enfoque universitario que integra múltiples registros semióticos.},
  langid = {spanish},
  keywords = {Duval},
  file = {/home/Dairo/Zotero/storage/97SNZER8/Iriarte et al. - 2025 - Dificultades en el aprendizaje de ecuaciones trigonométricas en estudiantes de primer año de ingenie.pdf}
