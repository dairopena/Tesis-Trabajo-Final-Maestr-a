@article{sanchezPersonalizacionRecursosPara2023,
  title = {Personalización de recursos para la enseñanza de matemáticas universitarias usando inteligencia artificial},
  author = {Sanchez, Juan Sebastian Parra and Pardo, Ingrid Durley Torres and family=Merino, given=Carmen Ysabel Martinez, prefix=de, useprefix=false},
  date = {2023-07-05},
  journaltitle = {Revista Interamericana de Investigación Educación y Pedagogía RIIEP},
  volume = {16},
  number = {1},
  pages = {319--340},
  issn = {2500-5421},
  doi = {10.15332/25005421.7904},
  url = {https://revistas.usantotomas.edu.co/index.php/riiep/article/view/7904},
  urldate = {2025-11-27},
  abstract = {Objective: to present a model for the personalization of learning resources using artificial intelligence (AI) techniques for the teaching of university mathematics. Methodology: The model was built based on the learning styles of Felder and Silverman and on a prior knowledge questionnaire applied to students in algebra, geometry and trigonometry once they enter professional engineering careers. Results: The recommendations of learning resources by learning styles were analyzed and AI techniques were applied, to find patterns in seven different groups of students. Conclusion: With this model, the possibility of making an adequate recommendation of learning resources was evaluated, considering the type and order of presentation of these and, in addition, on the areas that should be prioritized when entering the university.},
  langid = {spanish},
  file = {/home/Dairo/Zotero/storage/AP7UGQNL/Sanchez et al. - 2023 - Personalización de recursos para la enseñanza de matemáticas universitarias usando inteligencia arti.pdf}
}

