@article{canogullariTaskDesignPrinciples2025,
  title = {Task Design Principles in Mathematics Education: A Literature Review},
  shorttitle = {Task Design Principles in Mathematics Education},
  author = {Canogullari, Ahu and Radmehr, Farzad},
  date = {2025-02-25},
  journaltitle = {International Journal of Mathematical Education in Science and Technology},
  volume = {0},
  number = {0},
  pages = {1--33},
  publisher = {Taylor \& Francis},
  issn = {0020-739X},
  doi = {10.1080/0020739X.2025.2457365},
  url = {https://doi.org/10.1080/0020739X.2025.2457365},
  urldate = {2025-12-15},
  abstract = {In this study, we investigate the main principles underlying task design in mathematics education. Through a literature review, we identified four main categories that the principles for task design fall under: (1) inclusion, equity, and diversity, (2) cognitive aspect, (3) social aspect, and (4) affective aspect. Moreover, we discussed the role of the theoretical frameworks and sociocultural context in which the tasks are implemented as important elements influencing task design. We synthesised these categories into a framework that could facilitate dialogue about task design between practitioners (in schools and universities) and mathematics educators, while offering additional benefits. In particular, the devised framework can support teachers and lecturers to design, adapt, and/or select tasks for teaching mathematics. Additionally, the framework could serve as a valuable resource for discussions on task design with preservice teachers in teacher education programmes and for working with in-service teachers in professional development programmes or workshops.},
  keywords = {Diseño de tareas,Enseñanza de matemáticas,Principios,Revisión de la literatura},
  file = {/home/Dairo/Zotero/storage/3B6QBD3I/Canogullari y Radmehr - 2025 - Task design principles in mathematics education a literature review.pdf}
}

