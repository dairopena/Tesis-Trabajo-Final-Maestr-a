@article{romancanizaresRolIAEnsenanza2024,
  title = {El Rol de la IA en la Enseñanza de Matemáticas en Entornos Virtuales},
  author = {Román Cañizares, Gloria Narcisa},
  date = {2024-08-30},
  journaltitle = {Reincisol.},
  shortjournal = {Reincisol},
  volume = {3},
  number = {6},
  pages = {2111--2133},
  issn = {2953-6421},
  doi = {10.59282/reincisol.V3(6)2111-2133},
  url = {https://www.reincisol.com/ojs/index.php/reincisol/article/view/302},
  urldate = {2025-10-18},
  abstract = {This research examines the impact of artificial intelligence (AI) on mathematics education within virtual environments, emphasizing its growing importance for personalizing learning and enhancing the educational experience. The primary objective was to explore how AI-based tools can optimize math instruction on digital platforms by analyzing their influence on academic performance and student motivation. A bibliographic review methodology was employed using the PRISMA method, reviewing fifteen relevant articles to provide a comprehensive overview of the topic. The study assessed research on AI applications in mathematics education, from modeling techniques to innovative teaching strategies. Key findings reveal that AI significantly contributes to more adaptive and personalized instruction, improving student engagement and academic performance. However, limitations were also identified, such as the lack of studies in specific contexts and the need for further research to better understand long-term effects. The review highlights that while AI holds great promise for mathematics education in virtual environments, ongoing research is crucial to address associated challenges and maximize its benefits. This research underscores how AI integration can revolutionize math teaching while suggesting key areas for future research to further enhance the effectiveness of these technologies in education.},
  langid = {spanish},
  file = {/home/Dairo/Zotero/storage/M933YIGC/Román Cañizares - 2024 - El Rol de la IA en la Enseñanza de Matemáticas en Entornos Virtuales.pdf}
}

@article{roseroguevaraExploracionUsoInteligencia2025,
