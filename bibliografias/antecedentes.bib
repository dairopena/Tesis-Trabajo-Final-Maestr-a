@article{rendon-mesaOportunidadesTareasAutenticas2023,
  title = {Oportunidades de las tareas auténticas de modelación en el aprendizaje de la modelización matemática para la enseñanza. Un estudio con futuros profesores de matemáticas},
  author = {Rendón-Mesa, Paula Andrea and Parra-Zapata, Monica Marcela and Villa-Ochoa, Jhony Alexander},
