@article{magatFunctionalApproachTeaching2018,
  title = {Functional {{Approach}} in {{Teaching}} and {{Learning Plane Trigonometry}}},
  author = {Magat, Marita Salvo},
  date = {2018-06-26},
  journaltitle = {International Journal of Scientific Research and Management (IJSRM)},
  volume = {6},
  number = {06},
